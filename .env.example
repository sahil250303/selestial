# ═══════════════════════════════════════════════════════════════════
# SELESTIAL — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit your .env file — it is excluded by .gitignore.
# ═══════════════════════════════════════════════════════════════════

# ── REQUIRED: JWT Secret ─────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-64-char-random-hex-string

# ── REQUIRED: Admin password ──────────────────────────────────────────────────
ADMIN_PASSWORD=replace-with-strong-password

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
# Single canonical domain used for SEO (canonical/OG/sitemap). Keep both in sync.
SITE_URL=https://yourdomain.com
VITE_SITE_URL=https://yourdomain.com
# Comma-separated CORS allow-list (no wildcard).
ALLOWED_ORIGIN=https://yourdomain.com

# ── Database ──────────────────────────────────────────────────────────────────
# STRONGLY RECOMMENDED on serverless (Vercel): the bundled node:sqlite lives in an
# ephemeral /tmp and is wiped on every cold start. Use a durable libSQL/Turso DB.
# Create one free at turso.tech, then:
# TURSO_DATABASE_URL=libsql://your-db.turso.io
# TURSO_AUTH_TOKEN=your-turso-auth-token
# Local fallback (no Turso): defaults to ./server/database.sqlite
# SQLITE_DB_PATH=./server/database.sqlite

# ── Email / SMTP ──────────────────────────────────────────────────────────────
# Gmail: use an App Password (myaccount.google.com/apppasswords), not your login password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password
ADMIN_EMAIL=your-personal-email@gmail.com
STORE_NAME=Selestial

# ── Stripe (required for live card payments) ──────────────────────────────────
# Sign up at stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_your_stripe_publishable_key

# ── Google OAuth (required for real Google sign-in) ───────────────────────────
# console.cloud.google.com → APIs & Services → Credentials → Create OAuth 2.0 Client ID
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ── Twilio (optional — enables real OTP SMS) ──────────────────────────────────
# Sign up at twilio.com → Console → Account Info
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ── Vercel Blob (auto-configured by Vercel CLI — do not edit manually) ─────────
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...
