# SMTP Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password
ADMIN_EMAIL=your-personal-email@gmail.com
STORE_NAME=Selestial

# Other existing variables (example values)
JWT_SECRET=your-secret-key
ADMIN_PASSWORD=your-admin-password
SQLITE_DB_PATH=./server/database.sqlite
BLOB_READ_WRITE_TOKEN=your-vercel-blob-token

# Google Sign-In (OAuth 2.0 / Google Identity Services)
# Create a "Web application" OAuth 2.0 Client ID at https://console.cloud.google.com/apis/credentials
# and add your origin (e.g. http://localhost:5173 in dev, your prod URL in prod) to "Authorized JavaScript origins".
# The same client ID is used by the backend (to verify ID tokens) and the frontend (to render the Google button).
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
