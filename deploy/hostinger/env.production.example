# Required (recommended to override defaults)
PORT=3000
NODE_ENV=production

# Auth
JWT_SECRET=change-me-to-a-long-random-secret

# Admin user (username is 'admin')
ADMIN_PASSWORD=change-me

# SQLite (optional; default is ./server/database.sqlite)
SQLITE_DB_PATH=/var/www/selestial/server/database.sqlite

# Optional: order notification emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ADMIN_EMAIL=
STORE_NAME=Selestial

# Optional: OTP SMS (Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

